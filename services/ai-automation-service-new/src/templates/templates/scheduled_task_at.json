{
  "template_id": "scheduled_task_at",
  "version": 1,
  "description": "Execute action at a specific time (e.g., midnight, 7am)",
  "required_capabilities": {
    "services": []
  },
  "parameter_schema": {
    "schedule_pattern": {
      "type": "string",
      "required": true,
      "format": "HH:MM:SS",
      "description": "Time to trigger (e.g., '00:00:00' for midnight, '07:00:00' for 7am)"
    },
    "action_service": {
      "type": "string",
      "required": true,
      "description": "Service to call (e.g., 'light.turn_off')"
    },
    "target_entity": {
      "type": "string",
      "required": false,
      "default": "all",
      "description": "Target entity ID"
    },
    "target_area": {
      "type": "string",
      "required": false,
      "description": "Target area ID"
    },
    "action_data": {
      "type": "object",
      "required": false,
      "default": {},
      "description": "Additional action data"
    }
  },
  "safety_class": "low",
  "forbidden_targets": [],
  "compilation_mapping": {
    "trigger": [
      {
        "platform": "time",
        "at": "{{schedule_pattern}}"
      }
    ],
    "condition": null,
    "action": [
      {
        "service": "{{action_service}}",
        "target": {
          "entity_id": "{{target_entity}}",
          "area_id": "{{target_area}}"
        },
        "data": "{{action_data}}"
      }
    ],
    "alias_template": "Scheduled: {{action_service}} at {{schedule_pattern}}",
    "description_template": "Execute {{action_service}} at {{schedule_pattern}}"
  },
  "examples": [
    {
      "schedule_pattern": "00:00:00",
      "action_service": "light.turn_off",
      "target_entity": "all"
    },
    {
      "schedule_pattern": "07:00:00",
      "action_service": "light.turn_on",
      "target_area": "office",
      "action_data": {
        "brightness_pct": 100
      }
    }
  ]
}
