          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": false, "__name__": true, "datname": true, "instance": true, "job": true, "server": true },
            "renameByName": { "Value": "Dead Tuples", "relname": "Table", "schemaname": "Schema" }
          }
        }
      ],
      "type": "table"
    },
