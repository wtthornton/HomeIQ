          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "title": "Table Sizes",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": false, "__name__": true, "datname": true, "instance": true, "job": true, "server": true },
            "renameByName": { "Value": "Size", "relname": "Table", "schemaname": "Schema" }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
