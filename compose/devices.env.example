# compose/devices.env.example — Environment variables for device-management group
# Copy to devices.env and fill in values

# Home Assistant
HA_URL=http://homeassistant:8123
HA_HTTP_URL=
HA_TOKEN=
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Device Database
DEVICE_DATABASE_API_URL=
DEVICE_DATABASE_API_KEY=

# API Keys
API_KEY=hs_P3rU9kQ2xZp6vL1fYc7bN4sTqD8mA0wR

# InfluxDB (connection to core-platform)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=homeiq-token
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events

# Logging
LOG_LEVEL=INFO
