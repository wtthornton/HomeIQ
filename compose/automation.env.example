# compose/automation.env.example — Environment variables for automation-intelligence group
# Copy to automation.env and fill in values

# Home Assistant
HA_URL=http://homeassistant:8123
HA_HTTP_URL=
HA_WS_URL=
HA_TOKEN=
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2-codex

# API Keys
API_KEY=hs_P3rU9kQ2xZp6vL1fYc7bN4sTqD8mA0wR

# GitHub (for automation-miner, blueprint-index)
GITHUB_TOKEN=

# InfluxDB (connection to core-platform)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=homeiq-token
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events

# Logging
LOG_LEVEL=INFO
