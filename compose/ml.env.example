# compose/ml.env.example — Environment variables for ml-engine group
# Copy to ml.env and fill in values

# OpenAI
OPENAI_API_KEY=

# Model Configuration
MODEL_CACHE_DIR=/app/models
HF_HOME=/app/models
TRANSFORMERS_CACHE=/app/models

# Device Intelligence
DEVICE_INTELLIGENCE_PORT=8019
MQTT_BROKER=
MQTT_USERNAME=
MQTT_PASSWORD=

# Home Assistant
HA_HTTP_URL=
HA_WS_URL=
HA_TOKEN=
HOME_ASSISTANT_URL=

# InfluxDB (connection to core-platform)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=homeiq-token
INFLUXDB_ORG=homeiq

# Logging
LOG_LEVEL=INFO
