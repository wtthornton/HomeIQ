# compose/core.env.example — Environment variables for core-platform group
# Copy to core.env and fill in values

# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin123
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events
INFLUXDB_TOKEN=homeiq-token

# Data API
DATABASE_URL=sqlite+aiosqlite:///./data/metadata.db
API_KEY=hs_P3rU9kQ2xZp6vL1fYc7bN4sTqD8mA0wR
DEPLOYMENT_MODE=production

# Home Assistant
HA_HTTP_URL=
HA_WS_URL=
HA_TOKEN=
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
NABU_CASA_URL=
NABU_CASA_TOKEN=

# Logging
LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY=super-secret-jwt-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_PASSWORD=adminpass
