# compose/collectors.env.example — Environment variables for data-collectors group
# Copy to collectors.env and fill in values

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=
WEATHER_LOCATION=Las Vegas

# WattTime (Carbon Intensity)
WATTTIME_USERNAME=
WATTTIME_PASSWORD=
GRID_REGION=CAISO_NORTH

# Electricity Pricing
PRICING_PROVIDER=awattar
PRICING_API_KEY=

# Smart Meter
METER_TYPE=home_assistant
METER_API_TOKEN=
METER_DEVICE_ID=

# Home Assistant (for HA-based collectors)
HA_HTTP_URL=
HA_WS_URL=
HA_TOKEN=

# InfluxDB (connection to core-platform)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=homeiq-token
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events

# Logging
LOG_LEVEL=INFO
