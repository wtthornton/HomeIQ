# domains/energy-analytics/compose.env.example — Environment variables for energy-analytics domain
# Copy to compose.env and fill in values

# OpenAI (for proactive-agent-service)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIME=03:00

# Energy Correlator
ENERGY_CORRELATION_INTERVAL=60
ENERGY_LOOKBACK_MINUTES=5

# InfluxDB (connection to core-platform)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events

# Logging
LOG_LEVEL=INFO
