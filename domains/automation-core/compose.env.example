# domains/automation-core/compose.env.example — Environment variables for automation-core domain
# Copy to compose.env and fill in values

# Home Assistant
HA_URL=http://homeassistant:8123
HA_HTTP_URL=
HA_WS_URL=
HA_TOKEN=
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2-codex
OPENAI_YAML_MODEL=gpt-5.2-codex

# API Keys
API_KEY=changeme

# Data API (connection to core-platform)
DATA_API_URL=http://data-api:8006

# InfluxDB (connection to core-platform)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events

# Logging
LOG_LEVEL=INFO
