# domains/core-platform/compose.env.example — Environment variables for core-platform domain
# Copy to compose.env and fill in values

# InfluxDB
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=changeme
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events
INFLUXDB_TOKEN=changeme

# Data API
DATABASE_URL=sqlite+aiosqlite:///./data/metadata.db
API_KEY=changeme
DEPLOYMENT_MODE=production

# Home Assistant
HA_HTTP_URL=
HA_WS_URL=
HA_TOKEN=
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=
NABU_CASA_URL=
NABU_CASA_TOKEN=

# Weather (websocket-ingestion enrichment)
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5
WEATHER_DEFAULT_LOCATION=Las Vegas,NV,US

# Logging
LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY=changeme
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_PASSWORD=changeme
