# domains/device-management/compose.env.example — Environment variables for device-management domain
# Copy to compose.env and fill in values

# Home Assistant
HA_URL=http://homeassistant:8123
HA_HTTP_URL=
HA_TOKEN=
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Device Database
DEVICE_DATABASE_API_URL=
DEVICE_DATABASE_API_KEY=

# API Keys
API_KEY=changeme

# InfluxDB (connection to core-platform)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events

# Logging
LOG_LEVEL=INFO
