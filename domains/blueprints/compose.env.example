# domains/blueprints/compose.env.example — Environment variables for blueprints domain
# Copy to compose.env and fill in values

# GitHub (for automation-miner, blueprint-index)
GITHUB_TOKEN=

# API Keys
API_KEY=changeme

# Data API (connection to core-platform)
DATA_API_URL=http://data-api:8006

# Logging
LOG_LEVEL=INFO
