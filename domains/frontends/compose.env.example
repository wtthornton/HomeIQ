# domains/frontends/compose.env.example — Environment variables for frontends domain
# Copy to compose.env and fill in values

# API Configuration
API_BASE_URL=http://localhost:8004
API_KEY=changeme

# Vite (React UIs)
VITE_API_BASE_URL=
VITE_DATA_API_URL=
VITE_WS_URL=ws://localhost:8001/ws
VITE_ENVIRONMENT=production

# InfluxDB (for observability dashboard)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events

# Logging
LOG_LEVEL=INFO
