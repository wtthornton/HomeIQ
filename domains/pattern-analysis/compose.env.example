# domains/pattern-analysis/compose.env.example — Environment variables for pattern-analysis domain
# Copy to compose.env and fill in values

# Home Assistant
HA_URL=http://homeassistant:8123
HA_HTTP_URL=
HA_WS_URL=
HA_TOKEN=
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# MQTT (for ai-pattern-service)
MQTT_BROKER=
MQTT_PORT=1883

# InfluxDB (connection to core-platform)
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=homeiq
INFLUXDB_BUCKET=home_assistant_events

# Data API (connection to core-platform)
DATA_API_URL=http://data-api:8006

# Logging
LOG_LEVEL=INFO
