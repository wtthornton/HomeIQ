MANIFEST

# Simulation Framework (Epic AI-17/AI-18)
# Generated data and results are excluded, but source code is tracked
simulation/data/
simulation/results/
simulation/training_data/
simulation/*.pyc
simulation/**/__pycache__/
simulation/.pytest_cache/
simulation/.coverage
simulation/htmlcov/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Cursor MCP Configuration (contains API keys)
.cursor/mcp.json

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Node.js (for health-dashboard)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (with secrets/keys)
.env
.env.local
.env.development.local
.env.test
.env.test.local
.env.production.local
infrastructure/env.production
infrastructure/.env*
*.env
!*.env.example
!*.env.template
# Per-group compose env files (contain secrets — never commit)
compose/*.env
!compose/*.env.example

# Coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
coverage.json
.hypothesis/
.pytest_cache/

# Docker
.dockerignore

# Context7 KB temporary files (user-specific, session-based)
docs/kb/context7-cache/.refresh-queue
docs/kb/context7-cache/.refresh-queue.*
docs/kb/context7-cache/**/*.tmp

# Runtime database files
data/*.db
data/*.db-shm
data/*.db-wal
data/webhooks.db-*
!data/.gitkeep

# Service runtime database files
domains/*/data/*.db
domains/*/data/*.db-shm
domains/*/data/*.db-wal
domains/*/*/data/*.db
domains/*/*/data/*.db-shm
domains/*/*/data/*.db-wal

# Test results and coverage reports
test-results/
coverage/
!test-results/.gitkeep

# Analysis reports directory
reports/
!reports/.gitkeep

# Quality tool outputs
.pylint.d/
.mypy_cache/
.prospector/
.radon/

# ESLint cache
.eslintcache

# Jscpd reports
.jscpd/
jscpd-report/

# Temporary test files
test_nabu_casa_connection.py
ai_automation_backup.db
ha_events.log

# Backup files
*.backup
*.bak
.env.backup*

# Temporary data files
conversation_data.json
automation_from_ha.json
automation_actions.yaml
assistant_message.txt

# Debug scripts (should be in scripts/ or deleted)
debug_*.py

# Phase 3 embedding test artifacts
embedding_test_env/
embedding_tests/
embedding_test_output.log

# Cursor backup files
.cursor/background-agents.backup.*.yaml

# Windows reserved names
nul

# Playwright MCP test artifacts (screenshots from MCP testing)
.playwright-mcp/
.playwright-mcp/**/*

# Root-level temporary files (test artifacts, snapshots, logs)
test_results_*.txt
homeiq-*.txt
full_logs_*.txt
logs_*.txt
deployment_test_results.json

# Third-party library: home-assistant-datasets (git submodule)
# Allow the submodule directory itself (git tracks it)
!domains/tests/datasets/home-assistant-datasets/
# But ignore generated reports and cache files
domains/tests/datasets/home-assistant-datasets/reports/
domains/tests/datasets/home-assistant-datasets/.pytest_cache/
domains/tests/datasets/home-assistant-datasets/.mypy_cache/
domains/tests/datasets/home-assistant-datasets/__pycache__/
domains/tests/datasets/home-assistant-datasets/**/__pycache__/
# Keep datasets directory structure
!domains/tests/datasets/datasets/

# AI Training Data (large binary files - checkpoints, models, optimizer states)
domains/*/*/data/**/checkpoint-*/
domains/*/*/data/**/adapter_model.safetensors
domains/*/*/data/**/optimizer.pt
domains/*/*/data/**/scheduler.pt
domains/*/*/data/**/rng_state.pth
domains/*/*/data/**/training_args.bin
domains/*/*/data/**/tokenizer.json
domains/*/*/data/**/adapter_config.json
# Keep README and training_run.json for documentation
!domains/*/*/data/**/README.md
!domains/*/*/data/**/training_run.json

tests/playwright-report/

# Temporary folder for items pending deletion review
deleteme/

# Diagnostics folder (may contain secrets from docker inspect)
diagnostics/

# Backups folder (may contain large files and sensitive data)
backups/

# Migration backup folders and rollback scripts
domains/*/.migration_backup_*/
domains/*/rollback_*.sh
domains/*/*/.migration_backup_*/
domains/*/*/rollback_*.sh

# Phase 2 migration result files
phase2_results_*.json

# Claude Code local settings
.claude/settings.local.json
.claude/agent-memory/
.claude/agent-memory-local/

# TAPPS MCP runtime data (session metrics, not source code)
.tapps-mcp/metrics/
.tapps-mcp/sessions/
.tapps-mcp/pre-compact-context.json
