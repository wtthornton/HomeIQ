# HomeIQ Root Environment Variables
# Copy this file to .env and replace placeholder values with real keys.
#
#   cp .env.example .env
#
# The .env file is gitignored and will NOT be committed.

# ============================================================================
# OPENAI API
# ============================================================================
# Used by: automation-core (3 services), energy-analytics, ml-engine
OPENAI_API_KEY=example-openai-api-key

# ============================================================================
# HOME ASSISTANT
# ============================================================================
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=replace-with-your-ha-long-lived-access-token
HA_URL=http://homeassistant.local:8123
HA_TOKEN=replace-with-your-ha-long-lived-access-token

# ============================================================================
# MQTT BROKER
# ============================================================================
MQTT_USERNAME=replace-with-mqtt-username
MQTT_PASSWORD=replace-with-mqtt-password

# ============================================================================
# NABU CASA (optional cloud fallback)
# ============================================================================
# NABU_CASA_URL=https://your-instance.ui.nabu.casa
# NABU_CASA_TOKEN=replace-with-nabu-casa-token

# ============================================================================
# AI CORE SERVICE
# ============================================================================
AI_CORE_API_KEY=replace-with-ai-core-api-key
